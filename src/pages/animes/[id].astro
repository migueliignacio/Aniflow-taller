---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Tags from "../../components/Tags.astro";
import Navbar from "../../components/Navbar.astro";

export async function getStaticPaths() {
  const allAnime = await getCollection("anime");

  return allAnime.map((anime) => ({
    params: { id: anime.id },
    props: { anime },
  }));
}

const { anime } = Astro.props;
const { data } = anime;
const {
  title,
  genres,
  status,
  year,
  synopsis,
  coverImage,
  episodesCount,
  trailerUrl,
} = data;

const statuStyle: Record<string, string> = {
  finalizado: "bg-red-500/20 text-red-400 border-red-500/50",
  "en emisión": "bg-green-500/20 text-green-400 border-green-500/50",
  cancelado: "bg-amber-500/20 text-amber-400 border-amber-500/50",
  default: "bg-slate-400/20 text-slate-300 border-slate-400/50",
};

const currentStyle = statuStyle[status] || statuStyle["default"];
---

<Layout title={title}>
  <Navbar />
  <!-- HEADER / HERO SECTION -->
  <div class="relative w-full h-150 overflow-hidden bg-(--color-background)">
    <img
      src={coverImage}
      alt={title}
      class="w-full h-full object-cover blur-sm scale-110 opacity-50"
    />

    <div
      class="absolute inset-0 bg-linear-to-t from-(--color-background) via-(--color-background)/10 to-black/40"
    >
    </div>

    <!-- CONTENIDO DEL TEXTO: z-10 para que flote sobre el degradado -->
    <div class="absolute inset-0 flex flex-col justify-end z-10">
      <div class="m-10 space-y-3">
        <h1
          class="font-bold text-4xl uppercase text-(--color-text) drop-shadow-2xl"
        >
          {title}
        </h1>

        <div class="flex gap-2 uppercase font-bold text-(--color-text)">
          <p
            class="border-2 rounded-xl px-5 bg-slate-400/20 text-slate-300 border-slate-400/50"
          >
            {year}
          </p>

          <p
            class="border-2 rounded-xl px-5 bg-slate-400/20 text-slate-300 border-slate-400/50"
          >
            {episodesCount} Episodios
          </p>

          <p class={`border-2 rounded-xl px-5 ${currentStyle}`}>
            {status}
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- SECCIÓN DE DETALLES -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 mx-10 my-10 items-start">
    <div
      class="flex flex-col p-10 gap-6 text-(--color-text) bg-(--color-secondary) rounded-xl"
    >
      <div class="space-y-4">
        <div class="inline-block">
          <h2 class="text-3xl font-bold text-white mb-1">Sinopsis</h2>

          <div class="h-1 w-12 bg-(--color-primary) rounded-full"></div>
        </div>

        <p class="text-gray-400 leading-relaxed text-lg max-w-xl">
          {synopsis}
        </p>
      </div>

      <div class="flex gap-3 flex-wrap pt-4">
        {
          genres.map((tagName: string) => (
            <div class="opacity-80 hover:opacity-100 transition-opacity">
              <Tags name={tagName} />
            </div>
          ))
        }
      </div>
    </div>

    <section class="w-full group">
      <div
        class="relative aspect-video w-full rounded-2xl overflow-hidden shadow-[0_0_50px_rgba(0,0,0,0.5)] border border-white/5 bg-black/20"
      >
        <iframe
          src=`${trailerUrl}`
          title="YouTube video player"
          class="absolute inset-0 w-full h-full"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen></iframe>
      </div>
    </section>
  </div>
  <div>
    <h2>EPISODIOS</h2>
  </div>
</Layout>
