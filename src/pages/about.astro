---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="About">
  <Navbar />
  <main
    class="grid grid-cols-1 justify-items-center gap-12 my-16 px-4 mx-auto max-w-7xl"
  >
    <div class="flex flex-col items-center text-center space-y-4">
      <h1
        class="text-4xl md:text-5xl font-extrabold text-primary tracking-tight"
      >
        Sobre Nosotros
      </h1>
      <p class="text-lg md:text-xl max-w-2xl leading-relaxed text-gray-400">
        Aniflow nació de la frustración de perder tiempo buscando listas de
        episodios filler en sitios antiguos y desordenados.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full max-w-4xl">
      <div
        class="group rounded-3xl bg-black/5 backdrop-blur-md p-8 hover:border-primary/50 transition-all duration-300 flex flex-col"
      >
        <div
          class="max-w-max rounded-2xl bg-primary/10 p-3 mb-4 group-hover:scale-110 transition-transform"
        >
          <svg
            class="w-7 h-7 text-primary"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <h2 class="text-xl font-bold mb-3">Nuestra misión</h2>
        <p class="text-gray-400 leading-relaxed">
          Crear la plataforma más moderna y rápida para identificar episodios
          canon, relleno y mixtos. Diseñamos cada detalle pensando en la
          experiencia del usuario.
        </p>
      </div>

      <div
        class="group rounded-3xl bg-black/5 backdrop-blur-md p-8 hover:border-primary/50 transition-all duration-300 flex flex-col"
      >
        <div
          class="max-w-max rounded-2xl bg-primary/10 p-3 mb-4 group-hover:scale-110 transition-transform"
        >
          <svg
            class="w-7 h-7 text-primary"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
            ></path>
          </svg>
        </div>
        <h2 class="text-xl font-bold mb-3">Equipo</h2>
        <p class="text-gray-400 leading-relaxed">
          Somos un equipo de desarrolladores y fans del anime que creemos que tu
          tiempo es valioso. Cada episodio filler evitado es tiempo ganado para
          disfrutar la historia principal.
        </p>
      </div>
    </div>

    <div class="w-full max-w-4xl space-y-8">
      <h2 class="text-2xl md:text-3xl font-bold text-center">
        ¿Por qué confiar en Aniflow?
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center space-y-2">
          <div class="text-primary text-2xl flex justify-center">
            <svg
              width="24"
              height="24"
              fill="currentColor"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
              ><path
                d="M10.788 3.103c.495-1.004 1.926-1.004 2.421 0l2.358 4.777 5.273.766c1.107.161 1.549 1.522.748 2.303l-3.816 3.72.901 5.25c.19 1.103-.968 1.944-1.959 1.424l-4.716-2.48-4.715 2.48c-.99.52-2.148-.32-1.96-1.424l.901-5.25-3.815-3.72c-.801-.78-.359-2.142.748-2.303L8.43 7.88l2.358-4.777Z"
              ></path></svg
            >
          </div>
          <h3 class="font-semibold">Datos Curados</h3>
          <p class="text-gray-500 text-sm">
            Listas revisadas por la comunidad para asegurar precisión total.
          </p>
        </div>
        <div class="text-center space-y-2">
          <div class="text-primary text-2xl flex justify-center">
            <svg
              width="24"
              height="24"
              fill="currentColor"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
              ><path
                d="M3.28 2.22a.75.75 0 1 0-1.06 1.06l4.505 4.506-3.116.926A2.25 2.25 0 0 0 2 10.87v2.262a2.25 2.25 0 0 0 1.609 2.157l2.39.71L6 16.5l.005.2a4 4 0 0 0 7.59 1.556l5.123 1.524 2.001 2.002a.75.75 0 0 0 1.061-1.061L3.28 2.22ZM7.5 16.444l4.625 1.376A2.5 2.5 0 0 1 7.5 16.5l-.001-.056ZM22 17.738c0 .318-.066.621-.185.895L9.996 6.814l9.113-2.708A2.25 2.25 0 0 1 22 6.263v11.475Z"
              ></path></svg
            >
          </div>
          <h3 class="font-semibold">Sin Publicidad</h3>
          <p class="text-gray-500 text-sm">
            Navegación limpia, sin pop-ups molestos ni distracciones.
          </p>
        </div>
        <div class="text-center space-y-2">
          <div class="text-primary text-2xl flex justify-center">
            <svg
              width="24"
              height="24"
              fill="currentColor"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
              ><path
                d="M8.254 8.003c.967 0 1.75.784 1.75 1.75v9.5a1.75 1.75 0 0 1-1.75 1.75H3.75A1.75 1.75 0 0 1 2 19.253v-9.5c0-.966.784-1.75 1.75-1.75h4.504Zm-2.002 9.495h-.5a.75.75 0 1 0 0 1.5h.5a.75.75 0 0 0 0-1.5ZM21.25 16.5a.75.75 0 0 1 .102 1.493L21.25 18H11v-1.5h10.25ZM18.25 5c.966 0 1.75.784 1.75 1.75v7.5A1.75 1.75 0 0 1 18.25 16H11V9a2 2 0 0 0-1.85-1.994L9 7H4v-.25C4 5.784 4.784 5 5.75 5h12.5Z"
              ></path></svg
            >
          </div>
          <h3 class="font-semibold">Multiplataforma</h3>
          <p class="text-gray-500 text-sm">
            Optimizado para ver desde tu móvil, tablet o PC.
          </p>
        </div>
      </div>
    </div>

    <div
      class="w-full max-w-4xl bg-linear-to-r from-primary/20 to-transparent rounded-3xl p-8 md:p-12 text-center overflow-hidden relative group"
    >
      <div
        class="absolute inset-0 bg-primary/5 blur-3xl -z-10 group-hover:bg-primary/10 transition-colors"
      >
      </div>
      <h2 class="text-2xl md:text-4xl font-bold mb-4">
        ¿Listo para maratonear?
      </h2>
      <p class="mb-8 max-w-xl mx-auto">
        Explora nuestro catálogo y empieza a ver tu anime favorito como debe
        ser: centrado en la historia.
      </p>
      <a
        href="/animes"
        class="inline-block bg-primary font-bold px-8 py-4 rounded-2xl hover:scale-105 hover:shadow-[0_0_20px_rgba(var(--primary-rgb),0.4)] transition-all"
      >
        Ver Catálogo Completo
      </a>
    </div>
  </main>
  <Footer />
</Layout>
