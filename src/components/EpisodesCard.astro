---
interface Props {
  title: string;
  number: string | number;
  type: "canon" | "relleno" | "mixto";
  duration?: string;
}

const { title, number, type, duration }: Props = Astro.props;

const typeColors = {
  canon: "bg-canon",
  relleno: "bg-filler",
  mixto: "bg-mix",
};

const typeBadge = {
  canon: "bg-canon/30 text-canon/95",
  relleno: "bg-filler/30 text-filler/95",
  mixto: "bg-mix/30 text-mix/95",
};

const color = typeColors[type] || typeColors.canon;
const badgeColor = typeBadge[type] || typeBadge.canon;
---

<button
  type="button"
  class="episode-card group relative flex h-20 w-full items-center overflow-hidden rounded-lg border border-black/20 bg-bg-light dark:bg-bg-dark text-text-light dark:text-text-dark text-left shadow-sm transition-[transform,border-color,box-shadow,opacity] duration-300 ease-out hover:-translate-y-1 hover:border-primary/40 hover:shadow-[0_10px_30px_rgba(0,112,243,0.15)] active:scale-[0.98]"
  data-episode-number={number}
  aria-pressed="false"
>
  <div
    class={`absolute left-0 top-0 bottom-0 w-1 ${color} transition-all duration-300 group-hover:w-2`}
  >
  </div>

  <div
    class="absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100 bg-linear-to-r from-primary/5 via-transparent to-transparent"
  >
  </div>

  <div class="relative z-10 flex min-w-0 flex-1 items-center gap-4 px-4">
    <span
      class="whitespace-nowrap text-3xl font-black text-text-light dark:text-text-dark transition-transform duration-300 group-hover:scale-110 group-hover:text-primary"
    >
      {number}
    </span>

    <div class="flex min-w-0 flex-1 flex-col justify-center">
      <span
        class="truncate text-sm font-medium text-text-light dark:text-text-dark transition-colors duration-300 group-hover:text-primary"
      >
        {title}
      </span>

      <div class="mt-1 flex items-center gap-2">
        <span
          class={`rounded px-2 py-0.5 text-xs uppercase transition-transform duration-300 group-hover:scale-105 ${badgeColor}`}
        >
          {type}
        </span>

        {
          duration && (
            <span class="text-xs text-text-light dark:text-text-dark/50 transition-colors duration-300 group-hover:text-text-light dark:text-text-dark/70">
              {duration}
            </span>
          )
        }
      </div>
    </div>

    <div
      class="episode-check flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-text-light/10 dark:border-text-dark/10 bg-text-light/5 dark:bg-text-dark/5 text-xs text-text-light dark:text-text-dark/40 transition-all duration-300 group-hover:scale-110 group-hover:border-primary/40 group-hover:text-primary"
    >
      ✓
    </div>
  </div>
</button>
