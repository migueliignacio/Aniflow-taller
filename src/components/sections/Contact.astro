---
import { actions, isInputError } from "astro:actions";

const result = Astro.getActionResult(actions.sendSuggestion);
const actionError = result?.error;
const inputErrors =
  actionError && isInputError(actionError)
    ? Object.values(actionError.fields).flat()
    : [];

const feedbackClass = result?.data?.success
  ? "mt-6 block rounded-xl border border-green-400/20 bg-green-500/10 p-4 text-green-300"
  : result?.data?.success === false || actionError || inputErrors.length > 0
    ? "mt-6 block rounded-xl border border-red-400/20 bg-red-500/10 p-4 text-red-300"
    : "mt-6 hidden rounded-xl border p-4";
---

<section class="py-32 text-(--color-text)">
  <div class="mx-auto max-w-2xl px-6">
    <div
      class="rounded-3xl border border-black/10 bg-black/5 p-8 backdrop-blur dark:border-white/10 dark:bg-white/5"
    >
      <h2 class="text-4xl font-bold">Envíanos tus sugerencias</h2>

      <p class="mt-3 text-gray-400">Queremos mejorar la página contigo.</p>

      <div id="suggestion-feedback" class={feedbackClass} aria-live="polite">
        {
          result?.data?.success && (
            <p>{result.data.message}</p>
          )
        }

        {
          result?.data?.success === false && (
            <p>Error: {result.data.error}</p>
          )
        }

        {
          actionError && !isInputError(actionError) && (
            <p>Error: {actionError.message}</p>
          )
        }

        {
          inputErrors.length > 0 && (
            <>
              <p>Revisa el formulario:</p>
              <ul class="mt-2 list-disc space-y-1 pl-5">
                {inputErrors.map((error) => (
                  <li>{error}</li>
                ))}
              </ul>
            </>
          )
        }
      </div>

      <form
        id="suggestion-form"
        method="POST"
        action={actions.sendSuggestion}
        class="mt-8 space-y-5"
      >
        <input
          type="text"
          name="name"
          placeholder="Tu nombre"
          autocomplete="name"
          required
          minlength="2"
          maxlength="80"
          class="w-full rounded-xl border border-black/10 bg-black/10 px-4 py-3 outline-none focus:border-primary dark:border-white/10 dark:bg-white/10"
        />

        <input
          type="email"
          name="email"
          placeholder="Tu email"
          autocomplete="email"
          required
          maxlength="120"
          class="w-full rounded-xl border border-black/10 bg-black/10 px-4 py-3 outline-none focus:border-primary dark:border-white/10 dark:bg-white/10"
        />

        <textarea
          name="message"
          rows="6"
          placeholder="Escribe tu sugerencia..."
          required
          minlength="10"
          maxlength="2000"
          class="w-full resize-none rounded-xl border border-black/10 bg-black/10 px-4 py-3 outline-none focus:border-primary dark:border-white/10 dark:bg-white/10"
        ></textarea>

        <button
          type="submit"
          data-default-label="Enviar sugerencia"
          data-loading-label="Enviando..."
          class="w-full cursor-pointer rounded-xl bg-primary py-3 font-semibold transition hover:scale-[1.01] disabled:cursor-not-allowed disabled:opacity-70"
        >
          Enviar sugerencia
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  import { actions, isInputError } from "astro:actions";

  const form = document.querySelector<HTMLFormElement>("#suggestion-form");
  const feedback = document.querySelector<HTMLDivElement>("#suggestion-feedback");
  const button = form?.querySelector<HTMLButtonElement>('button[type="submit"]');

  function clearActionQuery() {
    const url = new URL(window.location.href);

    if (!url.searchParams.has("_action")) return;

    url.searchParams.delete("_action");
    window.history.replaceState(
      {},
      "",
      `${url.pathname}${url.search}${url.hash}`,
    );
  }

  function escapeHtml(value: string) {
    const div = document.createElement("div");
    div.textContent = value;
    return div.innerHTML;
  }

  function showMessage(kind: "success" | "error", html: string) {
    if (!feedback) return;

    feedback.className =
      kind === "success"
        ? "mt-6 block rounded-xl border border-green-400/20 bg-green-500/10 p-4 text-green-300"
        : "mt-6 block rounded-xl border border-red-400/20 bg-red-500/10 p-4 text-red-300";
    feedback.innerHTML = html;
  }

  function formatInputErrors(error: unknown) {
    if (!isInputError(error)) {
      return "<p>Error: No se pudo enviar la sugerencia.</p>";
    }

    const errors = Object.values(error.fields)
      .flat()
      .map((message) => `<li>${escapeHtml(String(message))}</li>`)
      .join("");

    return `<p>Revisa el formulario:</p><ul class="mt-2 list-disc space-y-1 pl-5">${errors}</ul>`;
  }

  clearActionQuery();

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (!form.reportValidity()) return;

    const defaultLabel = button?.dataset.defaultLabel ?? "Enviar sugerencia";
    const loadingLabel = button?.dataset.loadingLabel ?? "Enviando...";

    if (button) {
      button.disabled = true;
      button.textContent = loadingLabel;
    }

    try {
      const result = await actions.sendSuggestion(new FormData(form));

      if (result.data?.success) {
        showMessage("success", `<p>${escapeHtml(result.data.message)}</p>`);
        form.reset();
        return;
      }

      if (result.data?.success === false) {
        showMessage("error", `<p>Error: ${escapeHtml(result.data.error)}</p>`);
        return;
      }

      if (result.error) {
        showMessage(
          "error",
          isInputError(result.error)
            ? formatInputErrors(result.error)
            : `<p>Error: ${escapeHtml(result.error.message)}</p>`,
        );
      }
    } catch (error) {
      showMessage(
        "error",
        `<p>Error: ${escapeHtml(
          error instanceof Error
            ? error.message
            : "No se pudo enviar la sugerencia.",
        )}</p>`,
      );
    } finally {
      if (button) {
        button.disabled = false;
        button.textContent = defaultLabel;
      }
    }
  });
</script>
