---

---

<section id="features" class="pt-60 pb-20 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-20">
      <span
        class="inline-block px-4 py-1.5 rounded-md bg-[#8B5CF6]/10 border border-[#8B5CF6]/20 text-[#8B5CF6] text-sm font-medium mb-4"
        >Características</span
      >
      <h2
        class="font-display font-extrabold text-4xl md:text-5xl lg:text-6xl text-(--color-text) mb-6"
      >
        Todo lo que necesitas
      </h2>
      <p class="text-[#A1A1AA] text-lg md:text-xl max-w-2xl mx-auto">
        La herramienta definitiva para fans del anime que quieren optimizar su
        tiempo de visualización
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <div
        class="group relative rounded-2xl p-8 border border-bg-dark/15 dark:border-bg-light/15 hover:border-[#8B5CF6]/30 transition-all duration-500 overflow-hidden"
      >
        <div
          class="absolute inset-0 bg-linear-to-br from-[#8B5CF6]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"
        >
        </div>
        <div class="relative">
          <div
            class="w-14 h-14 rounded-2xl bg-linear-to-br from-[#8B5CF6]/20 to-[#8B5CF6]/5 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300"
          >
            <svg
              class="w-7 h-7 text-[#8B5CF6]"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"
              ></path>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-(--color-text) mb-3">
            Guías de episodios
          </h3>
          <p class="text-[#71717A] leading-relaxed">
            Consulta rápidamente episodios canon, relleno y mixtos de cualquier
            anime conocido.
          </p>
        </div>
      </div>

      <div
        class="group relative rounded-2xl p-8 border border-bg-dark/15 dark:border-bg-light/15 hover:border-[#EC4899]/30 transition-all duration-500 overflow-hidden"
      >
        <div
          class="absolute inset-0 bg-linear-to-br from-[#EC4899]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"
        >
        </div>
        <div class="relative">
          <div
            class="w-14 h-14 rounded-2xl bg-linear-to-br from-[#EC4899]/20 to-[#EC4899]/5 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300"
          >
            <svg
              class="w-7 h-7 text-[#EC4899]"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-(--color-text) mb-3">
            Buscador rápido
          </h3>
          <p class="text-[#71717A] leading-relaxed">
            Encuentra animes fácilmente por nombre, género o estudio de
            animación.
          </p>
        </div>
      </div>

      <div
        class="group relative rounded-2xl p-8 border border-bg-dark/15 dark:border-bg-light/15 hover:border-[#38BDF8]/30 transition-all duration-500 overflow-hidden"
      >
        <div
          class="absolute inset-0 bg-linear-to-br from-[#38BDF8]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"
        >
        </div>
        <div class="relative">
          <div
            class="w-14 h-14 rounded-2xl bg-linear-to-br from-[#38BDF8]/20 to-[#38BDF8]/5 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300"
          >
            <svg
              class="w-7 h-7 text-[#38BDF8]"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
              ></path>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-(--color-text) mb-3">
            Tema oscuro/claro
          </h3>
          <p class="text-[#71717A] leading-relaxed">
            Personaliza tu experiencia con temas visuales que se adaptan a ti.
          </p>
        </div>
      </div>

      <div
        class="group relative rounded-2xl p-8 border border-bg-dark/15 dark:border-bg-light/15 hover:border-[#22C55E]/30 transition-all duration-500 overflow-hidden"
      >
        <div
          class="absolute inset-0 bg-linear-to-br from-[#22C55E]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"
        >
        </div>
        <div class="relative">
          <div
            class="w-14 h-14 rounded-2xl bg-linear-to-br from-[#22C55E]/20 to-[#22C55E]/5 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300"
          >
            <svg
              class="w-7 h-7 text-[#22C55E]"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
              ></path>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-(--color-text) mb-3">
            Estadísticas
          </h3>
          <p class="text-[#71717A] leading-relaxed">
            Conoce porcentajes y duración estimada para planificar tu maratón.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
