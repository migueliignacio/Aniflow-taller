---

---

<section class="py-32 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-20">
      <span
        class="inline-block px-4 py-1.5 rounded-md bg-[#38BDF8]/10 border border-[#38BDF8]/20 text-[#38BDF8] text-sm font-medium mb-4"
        >Simple y rápido</span
      >
      <h2
        class="font-display font-extrabold text-4xl md:text-5xl lg:text-6xl text-(--color-text)"
      >
        ¿Cómo funciona?
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div class="relative text-center group">
        <div class="relative z-10">
          <div
            class="w-24 h-24 rounded-3xl bg-linear-to-br from-primary to-terciary flex items-center justify-center mx-auto mb-8 shadow-[0_0_60px_rgba(56,189,248,0.3)] group-hover:scale-110 transition-transform duration-500"
          >
            <span
              class="font-display font-extrabold text-4xl text-(--color-text)"
              >1</span
            >
          </div>
        </div>
        <div
          class="absolute top-12 left-1/2 w-full h-0.5 bg-linear-to-r from-transparent via-primary/30 to-transparent hidden md:block"
        >
        </div>
        <h3 class="font-display font-bold text-2xl text-(--color-text) mb-4">
          Busca tu anime
        </h3>
        <p class="text-[#71717A] text-lg max-w-xs mx-auto">
          Usa nuestro buscador ultrarrápido para encontrar cualquier serie
        </p>
      </div>

      <div class="relative text-center group">
        <div class="relative z-10">
          <div
            class="w-24 h-24 rounded-3xl bg-linear-to-br from-[#EC4899] to-[#38BDF8] flex items-center justify-center mx-auto mb-8 shadow-[0_0_60px_rgba(236,72,153,0.3)] group-hover:scale-110 transition-transform duration-500"
          >
            <span
              class="font-display font-extrabold text-4xl text-(--color-text)"
              >2</span
            >
          </div>
        </div>
        <div
          class="absolute top-12 left-1/2 w-full h-0.5 bg-linear-to-r from-transparent via-[#EC4899]/30 to-transparent hidden md:block"
        >
        </div>
        <h3 class="font-display font-bold text-2xl text-(--color-text) mb-4">
          Filtra episodios
        </h3>
        <p class="text-[#71717A] text-lg max-w-xs mx-auto">
          Selecciona ver solo canon, relleno o mixtos con un clic
        </p>
      </div>

      <div class="relative text-center group">
        <div class="relative z-10">
          <div
            class="w-24 h-24 rounded-3xl bg-linear-to-br from-primary to-terciary flex items-center justify-center mx-auto mb-8 shadow-[0_0_60px_rgba(56,189,248,0.3)] group-hover:scale-110 transition-transform duration-500"
          >
            <span
              class="font-display font-extrabold text-4xl text-(--color-text)"
              >3</span
            >
          </div>
        </div>
        <h3 class="font-display font-bold text-2xl text-(--color-text) mb-4">
          Mira sin relleno
        </h3>
        <p class="text-[#71717A] text-lg max-w-xs mx-auto">
          Disfruta la historia principal sin perder tiempo en episodios
          innecesarios
        </p>
      </div>
    </div>
  </div>
</section>
